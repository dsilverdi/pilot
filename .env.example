# Anthropic Authentication (one of the following)
# Priority: ANTHROPIC_OAUTH_TOKEN > ANTHROPIC_AUTH_TOKEN > ANTHROPIC_API_KEY
#
# Usage: export $(cat .env | xargs) && pilot

# Option 1: OAuth Token (highest priority)
# Used with Claude's OAuth flow, tokens start with "sk-ant-oat-"
ANTHROPIC_OAUTH_TOKEN=

# Option 2: Auth Token
ANTHROPIC_AUTH_TOKEN=

# Option 3: API Key (lowest priority)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api-xxxxx

# Web Search (optional)
# SearXNG URL for web search (default: http://localhost:8081)
SEARXNG_URL=http://localhost:8081

# Data Directory (optional, default: ~/.pilot)
# Set this for systemd deployments to use a shared location
#PILOT_HOME=/var/lib/pilot

# Gateway Configuration (optional)
GATEWAY_ADDR=:8080

# Telegram Bot (optional)
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=
# Restrict bot to specific user IDs (comma-separated, empty = allow all)
TELEGRAM_ALLOWED_USERS=
